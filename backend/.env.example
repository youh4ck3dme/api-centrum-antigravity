# .env template for API Centrum
# Kopírujte tento súbor ako .env a vyplňte reálne hodnoty

# API Kľúče
WEBSUPPORT_API_KEY=vaš_api_kľúč
WEBSUPPORT_SECRET=vaš_secret
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# Databáza (Vývoj: sqlite:///./test.db)
# Aplikácia beží na porte 5555 (hlavný) a 5556 (sekundárny).
DATABASE_URL=sqlite:///./test.db

# Certifikáty
CERTBOT_EMAIL=admin@example.com

# Nastavenia aplikácie
ENV=development
JWT_SECRET=generujte_nahodny_dlhy_string_aspon_32_znakov
JWT_EXPIRE_MINUTES=1440

# Bezpečnosť (Produkcia)
ALLOWED_HOSTS=localhost,127.0.0.1,vaša_doména.sk
CORS_ORIGINS=http://localhost:3000,https://vaša_doména.sk
